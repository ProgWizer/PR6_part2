<Page x:Class="wpfPr4.Pages.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:wpfPr4.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page2">

    <Grid>
        <ScrollViewer>
            <StackPanel Margin="20" Width="650">
                <TextBlock FontSize="20" FontWeight="Bold" Text="Страница 2 - Вариант 6 (g)" />
                
                
                
                <Border Margin="0,6,0,14" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="8">
                    <Image x:Name="ImgFormula2" Source="/Photo/Page2.jpg" Stretch="Uniform" Height="110" ToolTip="Пример (кусочная функция) — картинка. Путь можешь заменить на свой."/>
                </Border>
                
                
                
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="x:"/>
                    <TextBox x:Name="TbX" Grid.Row="0" Grid.Column="1" Margin="0,4"
                         ToolTip="Введите x"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="b:"/>
                    <TextBox x:Name="TbB" Grid.Row="1" Grid.Column="1" Margin="0,4"
                         ToolTip="Введите b (b ≠ 0 нужно для проверки x/b)"/>

                    <GroupBox Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" Header="Выбор f(x)" Margin="10,0,0,0"
                          ToolTip="Выберите функцию f(x)">
                        <StackPanel Margin="10">
                            <RadioButton x:Name="RbSinh" Content="sh(x)" IsChecked="True" />
                            <RadioButton x:Name="RbX2" Content="x^2" Margin="0,6,0,0"/>
                            <RadioButton x:Name="RbExp" Content="e^x" Margin="0,6,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Ответ:"/>
                    <TextBox x:Name="TbResult" Grid.Row="2" Grid.Column="1" Margin="0,4"
                         IsReadOnly="True" ToolTip="Значение g"/>
                </Grid>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Вычислить" Width="120" Margin="0,0,10,0"
                        ToolTip="Посчитать g" Click="Calc_Click"/>
                    <Button Content="Очистить" Width="120"
                        ToolTip="Очистить поля" Click="Clear_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

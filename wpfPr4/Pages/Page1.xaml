<Page x:Class="wpfPr4.Pages.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:wpfPr4.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page1">

    <Grid>
        <ScrollViewer>
            <StackPanel Margin="20" Width="520">
                <TextBlock FontSize="20" FontWeight="Bold" Text="Страница 1 — Вариант 6" />
               
                
                <Border Margin="0,6,0,14" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="8">
                    <Image x:Name="ImgFormula1" Source="/Photo/Page1.jpg" Stretch="Uniform" Height="90"/>
                </Border>
                
                
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="x:"/>
                    <TextBox x:Name="TbX" Grid.Row="0" Grid.Column="1" Margin="0,4"
                         ToolTip="Введите x (x ≥ 0)"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="y:"/>
                    <TextBox x:Name="TbY" Grid.Row="1" Grid.Column="1" Margin="0,4"
                         ToolTip="Введите y"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="z:"/>
                    <TextBox x:Name="TbZ" Grid.Row="2" Grid.Column="1" Margin="0,4"
                         ToolTip="Введите z (−1 ≤ z ≤ 1)"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Ответ:"/>
                    <TextBox x:Name="TbResult" Grid.Row="3" Grid.Column="1" Margin="0,4"
                         IsReadOnly="True" ToolTip="Результат вычисления"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Вычислить" Width="120" Margin="0,0,10,0"
                        ToolTip="Посчитать β" Click="Calc_Click"/>
                    <Button Content="Очистить" Width="120"
                        ToolTip="Очистить поля" Click="Clear_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
